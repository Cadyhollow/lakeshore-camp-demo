# ─────────────────────────────────────────────────────────────────────────────
# Environment template. Copy to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real keys. For a fully automated
# client setup, the ResoNation onboarding flow sets all of these on Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# ── Branding / identity ──────────────────────────────────────────────────────
# Public campground name shown in the UI and emails
NEXT_PUBLIC_CAMPGROUND_NAME=Your Campground
# Public location line (city, state)
NEXT_PUBLIC_CAMPGROUND_LOCATION=City, ST
# Public contact email shown to guests
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
# Public site URL (the live domain)
NEXT_PUBLIC_SITE_URL=https://your-campground.example.com
# Base URL used to build absolute links (usually same as the site URL)
NEXT_PUBLIC_BASE_URL=https://your-campground.example.com
# Internal client slug/id (onboarding sets this to the park_slug)
CAMPGROUND_ID=your-park-slug
# Theme colors (hex)
NEXT_PUBLIC_COLOR_PRIMARY=#2E6B8A
NEXT_PUBLIC_COLOR_SECONDARY=#C9D2D9
NEXT_PUBLIC_COLOR_DARK=#1C1C1C

# ── Supabase (this client's own project) ─────────────────────────────────────
# Project URL — https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Public anon key (browser-safe)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key (SERVER ONLY — full DB access, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin ────────────────────────────────────────────────────────────────────
# Password for the /admin login
ADMIN_PASSWORD=change-me

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Resend API key
RESEND_API_KEY=re_your_resend_key
# From address for guest-facing mail (must be a verified Resend domain)
RESEND_FROM_EMAIL=reservations@your-domain.com
# From address used for the internal/gmail path
RESEND_GMAIL_FROM=reservations@your-domain.com
# Reply-to address for guest mail
RESEND_REPLY_TO=hello@your-domain.com

# ── Payments (Square) ────────────────────────────────────────────────────────
# Public app id — production ids start with sq0idp- (must match SQUARE_ENVIRONMENT)
NEXT_PUBLIC_SQUARE_APP_ID=sq0idp-your-app-id
# 'production' or 'sandbox' (public) — must match the server-side SQUARE_ENVIRONMENT
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production
# Server-side app id (same value as the public one)
SQUARE_APPLICATION_ID=sq0idp-your-app-id
# Square OAuth application secret
SQUARE_APPLICATION_SECRET=your-square-app-secret
# Square access token for this location
SQUARE_ACCESS_TOKEN=your-square-access-token
# Square location id
SQUARE_LOCATION_ID=your-square-location-id
# 'production' or 'sandbox' — must match NEXT_PUBLIC_SQUARE_ENVIRONMENT
SQUARE_ENVIRONMENT=production
# Square webhook signature key (verifies incoming webhooks)
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key
